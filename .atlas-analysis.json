  "keyFeatures": [
    "GameObject-Component architecture (similar to Unity)",
    "OpenGL-based 3D rendering via OpenTK with perspective and orthographic cameras",
    "Jitter physics engine integration with colliders and rigid bodies",
    "Built-in FPS controller with wall-running and crouching",
    "Point light system with per-mesh emission and fog support",
    "OBJ mesh loading with texture, normal, and emission map support",
    "Audio playback engine via NAudio with sound caching",
    "Scene management with JSON-based scene files and hot-reloading",
    "UI system with textured boxes and bitmap text rendering",
    "Particle system with configurable lifetime, gravity, and jitter",
    "VR split-screen rendering support",
    "Debug line drawing utilities"
  ],
